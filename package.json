{
    "name": "study-signal",
    "version": "1.8.1",
    "private": true,
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "check": "bun run check:svelte && bun run check:ts",
        "check:svelte": "svelte-check",
        "check:ts": "tsc --noEmit",
        "test": "vitest run",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "postinstall": "wxt prepare"
    },
    "devDependencies": {
        "@tsconfig/svelte": "^5.0.8",
        "@types/bun": "latest",
        "@wxt-dev/module-svelte": "^2.0.4",
        "svelte": "^5.54.0",
        "svelte-check": "^4.4.5",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0",
        "wxt": "^0.20.20"
    },
    "dependencies": {
        "@fontsource/dm-sans": "^5.2.8",
        "@lucide/svelte": "^0.577.0",
        "@tailwindcss/vite": "^4.2.2",
        "tailwindcss": "^4.2.2",
        "tldts": "^7.0.26",
        "ufo": "^1.6.3"
    }
}
